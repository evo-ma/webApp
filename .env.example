# API base URL — set to your backend
# Development:
VITE_API_URL=http://localhost:3001/api
# Production (Hetzner):
# VITE_API_URL=https://evo.ma/api

# ── Web3Forms (email without backend) ────────────────────────────────────────
# 1. Go to https://web3forms.com
# 2. Enter contact@evo.ma and click "Create Access Key"
# 3. Paste the key below
VITE_WEB3FORMS_KEY=your_web3forms_access_key_here
